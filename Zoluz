<!DOCTYPE html>
<html>
<head>
<title>Mini ERP Inventory System</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:Arial;
margin:0;
background:#f4f6f9;
}

header{
background:#1E90FF;
color:white;
padding:15px;
text-align:center;
}

nav{
background:#2c3e50;
padding:10px;
text-align:center;
}

nav button{
margin:5px;
padding:10px 15px;
background:#FFA500;
border:none;
color:white;
cursor:pointer;
}

section{
display:none;
padding:20px;
}

.active{
display:block;
}

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

table,th,td{
border:1px solid #ccc;
}

th,td{
padding:10px;
text-align:center;
}

th{
background:#1E90FF;
color:white;
}

.lowstock{
background:#ffcccc;
font-weight:bold;
}

.login-box{
width:300px;
margin:120px auto;
background:white;
padding:30px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
}

input,button{
padding:10px;
margin:5px;
}

</style>
</head>

<body>

<header>
<h1>Inventory ERP System</h1>
</header>

<nav id="menu" style="display:none">

<button onclick="showPage('dashboard')">Dashboard</button>
<button onclick="showPage('materials')">Raw Materials</button>
<button onclick="showPage('issue')">Issue Product</button>
<button onclick="showPage('bom')">Bill Of Materials</button>
<button onclick="showPage('transactions')">Transactions</button>
<button onclick="logout()">Logout</button>

</nav>


<!-- LOGIN -->

<section id="login" class="active">

<div class="login-box">

<h2>Login</h2>

<input id="username" placeholder="Username">
<input id="password" type="password" placeholder="Password">

<button onclick="login()">Login</button>

<p id="loginMsg"></p>

</div>

</section>


<!-- DASHBOARD -->

<section id="dashboard">

<h2>Dashboard</h2>

<p>Raw Materials vs Components Used</p>

<canvas id="stockChart"></canvas>

</section>


<!-- RAW MATERIALS -->

<section id="materials">

<h2>Raw Material Stock</h2>

<form id="materialForm">

<input id="materialCode" placeholder="Material Code" required>
<input id="materialName" placeholder="Material Name" required>
<input id="materialQty" type="number" placeholder="Quantity" required>
<input id="materialBatch" placeholder="Batch Number" required>
<input id="materialExpiry" type="date" required>

<button>Add Material</button>

</form>

<table>

<thead>
<tr>
<th>Code</th>
<th>Name</th>
<th>Qty</th>
<th>Batch</th>
<th>Expiry</th>
<th>Status</th>
</tr>
</thead>

<tbody id="stockTable"></tbody>

</table>

</section>


<!-- ISSUE PRODUCT -->

<section id="issue">

<h2>Issue Product</h2>

<form id="issueForm">

<input id="productCode" placeholder="Product Code" required>
<input id="productName" placeholder="Material Name" required>
<input id="productQty" type="number" placeholder="Quantity Used" required>
<input id="productBatch" placeholder="Batch" required>

<button>Issue</button>

</form>

</section>


<!-- BOM -->

<section id="bom">

<h2>Bill Of Materials</h2>

<button onclick="printBOM()">Print BOM</button>

<table>

<thead>
<tr>
<th>Product Code</th>
<th>Material</th>
<th>Qty</th>
<th>Batch</th>
<th>Date</th>
</tr>
</thead>

<tbody id="bomTable"></tbody>

</table>

</section>


<!-- TRANSACTIONS -->

<section id="transactions">

<h2>Raw Material Transactions</h2>

<table>

<thead>
<tr>
<th>Date</th>
<th>User</th>
<th>Material</th>
<th>Qty</th>
<th>Type</th>
</tr>
</thead>

<tbody id="transactionTable"></tbody>

</table>

</section>



<script>

/* USERS */

let users={
Bernie:"bern123",
Siyanda:"siy456",
Lize:"liz789",
Tinotenda:"tin000",
Portfolio:"port555"
}

let currentUser=null


/* LOAD SAVED DATA */

let materials=JSON.parse(localStorage.getItem("materials")) || []
let products=JSON.parse(localStorage.getItem("products")) || []
let transactions=JSON.parse(localStorage.getItem("transactions")) || []

let chart

const LOW_STOCK=10


function saveData(){

localStorage.setItem("materials",JSON.stringify(materials))
localStorage.setItem("products",JSON.stringify(products))
localStorage.setItem("transactions",JSON.stringify(transactions))

}


/* PAGE NAVIGATION */

function showPage(page){

document.querySelectorAll("section").forEach(s=>s.classList.remove("active"))

document.getElementById(page).classList.add("active")

updateChart()

}


/* LOGIN */

function login(){

let u=document.getElementById("username").value
let p=document.getElementById("password").value

if(users[u]===p){

currentUser=u

document.getElementById("menu").style.display="block"

showPage("dashboard")

}
else{

document.getElementById("loginMsg").innerText="Login Failed"

}

}


function logout(){

location.reload()

}



/* ADD MATERIAL */

document.getElementById("materialForm").addEventListener("submit",function(e){

e.preventDefault()

if(currentUser!=="Tinotenda"){
alert("Only admin can add stock")
return
}

let code=document.getElementById("materialCode").value
let name=document.getElementById("materialName").value
let qty=parseInt(document.getElementById("materialQty").value)
let batch=document.getElementById("materialBatch").value
let expiry=document.getElementById("materialExpiry").value

materials.push({code,name,qty,batch,expiry})

transactions.push({
date:new Date().toLocaleDateString(),
user:currentUser,
material:name,
qty:qty,
type:"Stock In"
})

saveData()

renderStock()
renderTransactions()
updateChart()

this.reset()

})



/* RENDER STOCK */

function renderStock(){

let table=document.getElementById("stockTable")

table.innerHTML=""

materials.forEach(m=>{

let status="OK"
let row=""

if(m.qty<=LOW_STOCK){
status="LOW STOCK"
row="lowstock"
}

table.innerHTML+=`

<tr class="${row}">
<td>${m.code}</td>
<td>${m.name}</td>
<td>${m.qty}</td>
<td>${m.batch}</td>
<td>${m.expiry}</td>
<td>${status}</td>
</tr>

`

})

}



/* ISSUE MATERIAL */

document.getElementById("issueForm").addEventListener("submit",function(e){

e.preventDefault()

if(currentUser!=="Tinotenda"){
alert("Only admin can issue stock")
return
}

let code=document.getElementById("productCode").value
let name=document.getElementById("productName").value
let qty=parseInt(document.getElementById("productQty").value)
let batch=document.getElementById("productBatch").value

let material=materials.find(m=>m.name.toLowerCase()===name.toLowerCase())

if(!material || material.qty<qty){
alert("Not enough stock")
return
}

material.qty-=qty

let date=new Date().toLocaleDateString()

products.push({code,name,qty,batch,date})

transactions.push({
date,
user:currentUser,
material:name,
qty,
type:"Stock Out"
})

saveData()

renderStock()
renderBOM()
renderTransactions()
updateChart()

this.reset()

})



/* BOM */

function renderBOM(){

let table=document.getElementById("bomTable")

table.innerHTML=""

products.forEach(p=>{

table.innerHTML+=`

<tr>
<td>${p.code}</td>
<td>${p.name}</td>
<td>${p.qty}</td>
<td>${p.batch}</td>
<td>${p.date}</td>
</tr>

`

})

}



/* TRANSACTIONS */

function renderTransactions(){

let table=document.getElementById("transactionTable")

table.innerHTML=""

transactions.forEach(t=>{

table.innerHTML+=`

<tr>
<td>${t.date}</td>
<td>${t.user}</td>
<td>${t.material}</td>
<td>${t.qty}</td>
<td>${t.type}</td>
</tr>

`

})

}



/* DASHBOARD CHART */

function updateChart(){

let totalMaterials=0
let totalUsed=0

materials.forEach(m=>{
totalMaterials+=m.qty
})

products.forEach(p=>{
totalUsed+=p.qty
})

let ctx=document.getElementById("stockChart")

if(!ctx) return

if(chart){
chart.destroy()
}

chart=new Chart(ctx,{
type:'pie',
data:{
labels:['Raw Materials In Stock','Components Used'],
datasets:[{
data:[totalMaterials,totalUsed],
backgroundColor:['#1E90FF','#FFA500']
}]
}
})

}



/* PRINT BOM */

function printBOM(){

let table=document.getElementById("bom").innerHTML

let win=window.open()

win.document.write("<h1>Bill Of Materials</h1>"+table)

win.print()

}


/* LOAD DATA */

renderStock()
renderBOM()
renderTransactions()
updateChart()

</script>

</body>
</html>
